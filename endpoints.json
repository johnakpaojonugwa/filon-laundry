  "httpStatusCodes": {
    "200": "Success",
    "201": "Created",
    "400": "Bad Request (validation errors)",
    "401": "Unauthorized (missing/invalid token)",
    "403": "Forbidden (insufficient permissions)",
    "404": "Not Found",
    "409": "Conflict (duplicate entries)",
    "500": "Server Error"
  },
  "roles": {
    "super_admin": "Full system access",
    "branch_manager": "Branch-level access",
    "staff": "Limited operational access",
    "customer": "Self-service only"
  },
  "rateLimiting": {
    "authEndpoints": "3 requests per 15 minutes for token refresh, other auth endpoints use the general rate limiter",
    "otherEndpoints": "100 requests per 15 minutes"
  }
}
